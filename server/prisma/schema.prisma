datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum OrgStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
}

enum Role {
  ADMIN
  EMPLOYEE
}

model Organization {
  id          Int        @id @default(autoincrement()) @db.UnsignedInt
  name        String     @db.VarChar(150)
  companyCode String     @unique @map("company_code") @db.VarChar(50)
  email       String     @db.VarChar(100)
  phone       String?    @db.VarChar(20)
  address     String?    @db.Text
  logo        String?    @db.VarChar(255)
  website     String?    @db.VarChar(255)
  status      OrgStatus  @default(ACTIVE)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  users       User[]

  @@index([status], map: "idx_org_status")
  @@map("organizations")
}

model User {
  id             Int            @id @default(autoincrement()) @db.UnsignedInt
  organizationId Int            @map("organization_id") @db.UnsignedInt
  employeeId     String         @map("employee_id") @db.VarChar(50)
  name           String         @db.VarChar(100)
  email          String         @unique @db.VarChar(100)
  password       String         @db.VarChar(255)
  phone          String?        @db.VarChar(20)
  department     String?        @db.VarChar(100)
  designation    String?        @db.VarChar(100)
  avatar         String?        @db.VarChar(255)
  role           Role           @default(EMPLOYEE)
  status         UserStatus     @default(ACTIVE)
  lastLogin      DateTime?      @map("last_login") @db.Timestamp(0)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  organization      Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  refreshTokens     RefreshToken[]
  savedPlaces       SavedPlace[]
  vehicles          Vehicle[]
  rides             Ride[]
  passengerBookings Booking[]      @relation("PassengerBookings")
  driverBookings    Booking[]      @relation("DriverBookings")
  wallet            Wallet?
  walletTransactions WalletTransaction[]
  paymentsPaid      Payment[]      @relation("PaymentPayer")
  paymentsReceived  Payment[]      @relation("PaymentReceiver")
  reviewsGiven       RideReview[]   @relation("ReviewsGiven")
  reviewsReceived    RideReview[]   @relation("ReviewsReceived")
  driverHistories    RideHistory[]  @relation("DriverHistory")
  passengerHistories RideHistory[]  @relation("PassengerHistory")
  notifications            Notification[]
  notificationPreference   NotificationPreference?
  emailQueue               EmailQueue[]

  @@unique([organizationId, employeeId], name: "idx_user_org_emp")
  @@index([role], map: "idx_user_role")
  @@index([status], map: "idx_user_status")
  @@map("users")
}

model SavedPlace {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  userId    Int      @map("user_id") @db.UnsignedInt
  placeName String   @map("place_name") @db.VarChar(100)
  address   String   @db.VarChar(255)
  latitude  Decimal  @db.Decimal(10, 8)
  longitude Decimal  @db.Decimal(11, 8)
  isDefault Int      @default(0) @map("is_default") @db.TinyInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId], map: "idx_saved_places_user_id")
  @@map("saved_places")
}

model RefreshToken {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  userId    Int      @map("user_id") @db.UnsignedInt
  token     String   @unique @db.VarChar(512)
  expiresAt DateTime @map("expires_at") @db.Timestamp(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId], map: "idx_refresh_user_id")
  @@map("refresh_tokens")
}

model Vehicle {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  userId      Int      @map("user_id") @db.UnsignedInt
  model       String   @db.VarChar(100)
  plateNumber String   @unique @map("plate_number") @db.VarChar(50)
  color       String   @db.VarChar(50)
  capacity    Int      @db.Int
  type        String?  @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  rides       Ride[]

  @@index([userId], map: "idx_vehicles_user_id")
  @@map("vehicles")
}

model Ride {
  id                  Int          @id @default(autoincrement()) @db.UnsignedInt
  driverId            Int          @map("driver_id") @db.UnsignedInt
  vehicleId           Int          @map("vehicle_id") @db.UnsignedInt
  pickupName          String       @map("pickup_name") @db.VarChar(255)
  pickupLocation      Unsupported("point") @map("pickup_location")
  destinationName     String       @map("destination_name") @db.VarChar(255)
  destinationLocation Unsupported("point") @map("destination_location")
  departureTime       DateTime     @map("departure_time") @db.DateTime(0)
  availableSeats      Int          @map("available_seats") @db.Int
  farePerSeat         Decimal      @map("fare_per_seat") @db.Decimal(10, 2)
  distanceKm          Decimal?     @map("distance_km") @db.Decimal(10, 2)
  estimatedDuration   Int?         @map("estimated_duration") @db.Int
  routeGeometry       String?      @map("route_geometry") @db.LongText
  rideStatus          RideStatus   @default(Scheduled) @map("ride_status")
  isRecurring         Boolean      @default(false) @map("is_recurring")
  notes               String?      @db.Text
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt           DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  driver              User         @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle             Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  bookings            Booking[]
  histories           RideHistory[]
  reviews             RideReview[]

  @@index([driverId], map: "idx_rides_driver_id")
  @@index([departureTime], map: "idx_rides_departure_time")
  @@index([rideStatus], map: "idx_rides_status")
  @@map("rides")
}

enum RideStatus {
  Scheduled
  Started
  InProgress @map("In Progress")
  Completed
  Cancelled
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  COMPLETED
}

model Booking {
  id             Int           @id @default(autoincrement()) @db.UnsignedInt
  rideId         Int           @map("ride_id") @db.UnsignedInt
  passengerId    Int           @map("passenger_id") @db.UnsignedInt
  driverId       Int           @map("driver_id") @db.UnsignedInt
  requestedSeats Int           @map("requested_seats") @db.Int
  status         BookingStatus @default(PENDING)
  bookingDate    DateTime      @default(now()) @map("booking_date") @db.Timestamp(0)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  ride      Ride    @relation(fields: [rideId], references: [id], onDelete: Cascade)
  passenger User    @relation("PassengerBookings", fields: [passengerId], references: [id], onDelete: Cascade)
  driver    User    @relation("DriverBookings", fields: [driverId], references: [id], onDelete: Cascade)
  payment   Payment?

  @@index([rideId], map: "idx_booking_ride_id")
  @@index([passengerId], map: "idx_booking_passenger_id")
  @@index([driverId], map: "idx_booking_driver_id")
  @@map("bookings")
}

// ─── Module 10: Wallet & Payments ──────────────────────────────────────────────

enum WalletStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum TransactionType {
  RECHARGE
  RIDE_PAYMENT
  REFUND
  ADJUSTMENT
  REWARD
}

enum PaymentMethod {
  WALLET
  CASH
  UPI
  RAZORPAY
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model Wallet {
  id           Int                 @id @default(autoincrement()) @db.UnsignedInt
  userId       Int                 @unique @map("user_id") @db.UnsignedInt
  balance      Decimal             @default(0.00) @db.Decimal(12, 2)
  status       WalletStatus        @default(ACTIVE)
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  transactions WalletTransaction[]

  @@index([status], map: "idx_wallet_status")
  @@map("wallets")
}

model WalletTransaction {
  id              Int             @id @default(autoincrement()) @db.UnsignedInt
  walletId        Int             @map("wallet_id") @db.UnsignedInt
  userId          Int             @map("user_id") @db.UnsignedInt
  bookingId       Int?            @map("booking_id") @db.UnsignedInt
  paymentId       Int?            @map("payment_id") @db.UnsignedInt
  transactionType TransactionType @map("transaction_type")
  amount          Decimal         @db.Decimal(12, 2)
  balanceBefore   Decimal         @map("balance_before") @db.Decimal(12, 2)
  balanceAfter    Decimal         @map("balance_after") @db.Decimal(12, 2)
  referenceNo     String          @unique @map("reference_no") @db.VarChar(64)
  description     String?         @db.VarChar(255)
  status          PaymentStatus   @default(SUCCESS)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamp(0)

  wallet  Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([walletId], map: "idx_txn_wallet_id")
  @@index([userId], map: "idx_txn_user_id")
  @@index([bookingId], map: "idx_txn_booking_id")
  @@index([transactionType], map: "idx_txn_type")
  @@index([status], map: "idx_txn_status")
  @@map("wallet_transactions")
}

model Payment {
  id                   Int           @id @default(autoincrement()) @db.UnsignedInt
  bookingId            Int           @unique @map("booking_id") @db.UnsignedInt
  payerId              Int           @map("payer_id") @db.UnsignedInt
  receiverId           Int           @map("receiver_id") @db.UnsignedInt
  paymentMethod        PaymentMethod @map("payment_method")
  amount               Decimal       @db.Decimal(12, 2)
  status               PaymentStatus @default(PENDING)
  transactionReference String?       @map("transaction_reference") @db.VarChar(128)
  gatewayOrderId       String?       @map("gateway_order_id") @db.VarChar(128)
  gatewayPaymentId     String?       @map("gateway_payment_id") @db.VarChar(128)
  gatewaySignature     String?       @map("gateway_signature") @db.VarChar(256)
  paidAt               DateTime?     @map("paid_at") @db.Timestamp(0)
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamp(0)

  booking  Booking @relation(fields: [bookingId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  payer    User    @relation("PaymentPayer", fields: [payerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  receiver User    @relation("PaymentReceiver", fields: [receiverId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([payerId], map: "idx_payment_payer")
  @@index([receiverId], map: "idx_payment_receiver")
  @@index([status], map: "idx_payment_status")
  @@index([paymentMethod], map: "idx_payment_method")
  @@map("payments")
}

// ─── Module 11: Ride History & Reviews ──────────────────────────────────────────

model RideHistory {
  id            Int        @id @default(autoincrement()) @db.UnsignedInt
  rideId        Int        @map("ride_id") @db.UnsignedInt
  driverId      Int        @map("driver_id") @db.UnsignedInt
  passengerId   Int        @map("passenger_id") @db.UnsignedInt
  farePaid      Decimal    @map("fare_paid") @db.Decimal(10, 2)
  distance      Decimal    @map("distance") @db.Decimal(10, 2)
  duration      Int        @map("duration") @db.Int
  pickup        String     @map("pickup") @db.VarChar(255)
  dropoff       String     @map("dropoff") @db.VarChar(255)
  rideDate      DateTime   @map("ride_date") @db.Timestamp(0)
  status        RideStatus @map("status")
  paymentStatus String     @map("payment_status") @db.VarChar(50)
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamp(0)

  ride          Ride       @relation(fields: [rideId], references: [id], onDelete: Cascade)
  driver        User       @relation("DriverHistory", fields: [driverId], references: [id], onDelete: Cascade)
  passenger     User       @relation("PassengerHistory", fields: [passengerId], references: [id], onDelete: Cascade)

  @@index([rideId], map: "idx_history_ride_id")
  @@index([driverId], map: "idx_history_driver_id")
  @@index([passengerId], map: "idx_history_passenger_id")
  @@map("ride_histories")
}

model RideReview {
  id         Int      @id @default(autoincrement()) @db.UnsignedInt
  rideId     Int      @map("ride_id") @db.UnsignedInt
  reviewerId Int      @map("reviewer_id") @db.UnsignedInt
  revieweeId Int      @map("reviewee_id") @db.UnsignedInt
  rating     Int      @map("rating") @db.Int
  review     String   @map("review") @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  ride       Ride     @relation(fields: [rideId], references: [id], onDelete: Cascade)
  reviewer   User     @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee   User     @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)

  @@unique([reviewerId, revieweeId, rideId], name: "idx_review_unique_pair")
  @@index([rideId], map: "idx_review_ride_id")
  @@index([reviewerId], map: "idx_review_reviewer_id")
  @@index([revieweeId], map: "idx_review_reviewee_id")
  @@map("ride_reviews")
}

// ─── Module 12: Notifications & Communication ──────────────────────────────────

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum NotificationCategory {
  BOOKING
  PAYMENT
  RIDE
  SYSTEM
  PROFILE
  REMINDER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

model Notification {
  id        Int                  @id @default(autoincrement()) @db.UnsignedInt
  userId    Int                  @map("user_id") @db.UnsignedInt
  title     String               @db.VarChar(255)
  message   String               @db.Text
  type      NotificationType     @default(INFO)
  category  NotificationCategory @default(SYSTEM)
  priority  Priority             @default(MEDIUM)
  isRead    Boolean              @default(false) @map("is_read")
  actionUrl String?              @map("action_url") @db.VarChar(500)
  metadata  Json?                @db.Json
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId], map: "idx_notification_user_id")
  @@index([isRead], map: "idx_notification_is_read")
  @@index([category], map: "idx_notification_category")
  @@index([createdAt], map: "idx_notification_created_at")
  @@map("notifications")
}

model NotificationPreference {
  id                       Int      @id @default(autoincrement()) @db.UnsignedInt
  userId                   Int      @unique @map("user_id") @db.UnsignedInt
  emailEnabled             Boolean  @default(true) @map("email_enabled")
  pushEnabled              Boolean  @default(true) @map("push_enabled")
  inAppEnabled             Boolean  @default(true) @map("in_app_enabled")
  bookingNotifications     Boolean  @default(true) @map("booking_notifications")
  paymentNotifications     Boolean  @default(true) @map("payment_notifications")
  rideReminderNotifications Boolean @default(true) @map("ride_reminder_notifications")
  systemNotifications      Boolean  @default(true) @map("system_notifications")
  marketingNotifications   Boolean  @default(false) @map("marketing_notifications")
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt                DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("notification_preferences")
}

model EmailQueue {
  id          Int         @id @default(autoincrement()) @db.UnsignedInt
  userId      Int         @map("user_id") @db.UnsignedInt
  recipient   String      @db.VarChar(255)
  subject     String      @db.VarChar(500)
  body        String      @db.LongText
  status      EmailStatus @default(PENDING)
  retryCount  Int         @default(0) @map("retry_count") @db.Int
  scheduledAt DateTime?   @map("scheduled_at") @db.Timestamp(0)
  sentAt      DateTime?   @map("sent_at") @db.Timestamp(0)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamp(0)

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId], map: "idx_email_queue_user_id")
  @@index([status], map: "idx_email_queue_status")
  @@index([scheduledAt], map: "idx_email_queue_scheduled")
  @@map("email_queue")
}
