{
  "name": "enterprise-carpooling-workspace",
  "version": "1.0.0",
  "description": "Monorepo Workspace for Enterprise Carpooling Platform",
  "private": true,
  "scripts": {
    "postinstall": "npm run install:all",
    "install:server": "cd server && npm install",
    "install:client": "cd client && npm install --legacy-peer-deps",
    "install:all": "concurrently \"npm run install:server\" \"npm run install:client\"",
    "db:prep": "node server/scripts/dbPrep.js",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "start": "npm run db:prep && concurrently --kill-others \"npm run dev:server\" \"npm run dev:client\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {}
}
