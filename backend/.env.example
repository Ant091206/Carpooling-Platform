# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=rootpassword
DB_NAME=enterprise_carpool

# Prisma Database URL
DATABASE_URL="mysql://root:rootpassword@localhost:3306/enterprise_carpool"

# JWT Configuration
# Note: Generate strong random secret keys for production
JWT_SECRET=your_jwt_access_secret_key_here_32_bytes
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_32_bytes

# File Upload Configuration
UPLOAD_PATH=uploads/

# Mapbox Configuration
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here